<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Prototype.LisätiedotClient"
             Title="Juttunurkka"
             BackgroundColor="Transparent"
             BackgroundImageSource="background3.png">

    <ContentPage.Content>
        
        <StackLayout Padding="0,80,0,0">
        
            <!--Tekstiosa-->
            <Label
                Text="TULOKSET"
                FontSize="40"
                FontAttributes="Bold"
                FontFamily="LineSeedBold"
                TextColor="Black"
                HorizontalOptions="Center"
                Margin="0,30,0,50"/>

            <!--Tulokset pylväinä-->
            <CollectionView
                ItemsSource="{Binding Results}"
                HorizontalOptions="Center"
                Margin="0,0,0,20">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="0"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <StackLayout
                            WidthRequest="100"
                            VerticalOptions="EndAndExpand"
                            HorizontalOptions="Center"
                            Spacing="0">

                            <Image
                                Source="{Binding Image}"
                                HeightRequest="80"
                                HorizontalOptions="Center"/>

                            <Grid
                                HeightRequest="300"
                                VerticalOptions="FillAndExpand">
                                <Frame
                                    VerticalOptions="End"
                                    HeightRequest="{Binding ScalePx}"
                                    MinimumHeightRequest="160"
                                    WidthRequest="60"
                                    BackgroundColor="#bfd3c1"
                                    CornerRadius="10"
                                    Padding="0"
                                    HasShadow="False">
                                    <Label
                                        Text="{Binding Amount}"
                                        TextColor="Black"
                                        FontFamily="LineSeedBold"
                                        FontSize="30"
                                        FontAttributes="Bold"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"/>
                                </Frame>
                            </Grid>

                            <!--Pylväiden alla oleva viiva-->
                            <BoxView
                                HeightRequest="8"
                                BackgroundColor="#a0baa3"
                                VerticalOptions="End"
                                Margin="0,0,0,25"
                                HorizontalOptions="FillAndExpand"/>
                            
                        </StackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </StackLayout>
    </ContentPage.Content>
</ContentPage>
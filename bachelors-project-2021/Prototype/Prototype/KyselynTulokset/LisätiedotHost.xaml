<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Prototype.LisätiedotHost"
             Title="Juttunurkka"
             BackgroundColor="#FFEA7F">

    <ContentPage.Content>
        <StackLayout Padding="0,80,0,0">

            <Label
                Text="TULOKSET"
                FontSize="40"
                FontAttributes="Bold"
                FontFamily="BebasNeue"
                TextColor="Black"
                HorizontalOptions="Center"
                Margin="0,30,0,50"/>

            <CollectionView
                ItemsSource="{Binding Results}"
                HorizontalOptions="Center"
                Margin="0,0,0,20">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10"/>
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <StackLayout
                            WidthRequest="130"
                            VerticalOptions="EndAndExpand"
                            HorizontalOptions="Center"
                            Spacing="8">

                            <Image
                                Source="{Binding Image}"
                                HeightRequest="80"
                                HorizontalOptions="Center"/>

                            <Label
                                Text="{Binding Title}"
                                FontSize="14"
                                HorizontalTextAlignment="Center"
                                TextColor="Black"
                                LineBreakMode="WordWrap"/>

                            <Grid
                                HeightRequest="200"
                                VerticalOptions="FillAndExpand">
                                <Frame
                                    VerticalOptions="End"
                                    HeightRequest="{Binding ScalePx}"
                                    WidthRequest="60"
                                    BackgroundColor="#FEBA4F"
                                    CornerRadius="5"
                                    Padding="0"
                                    HasShadow="False">
                                    <Label
                                        Text="{Binding Amount}"
                                        TextColor="Black"
                                        FontSize="30"
                                        FontAttributes="Bold"
                                        HorizontalOptions="Center"
                                        VerticalOptions="Center"/>
                                </Frame>
                            </Grid>

                            <BoxView
                                HeightRequest="8"
                                BackgroundColor="#C381FD"
                                VerticalOptions="End"
                                Margin="0,0,0,8"
                                HorizontalOptions="FillAndExpand"/>

                            <!-- tähän tulee lista piirretyistä emojeista "draw your own" palkin alle -->
                            <CollectionView
                                ItemsSource="{Binding DrawnImages}"
                                VerticalOptions="Start"
                                HeightRequest="180"
                                IsVisible="{Binding DrawnImages.Count}">
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="6"/>
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Frame
                                            Padding="4"
                                            Margin="0"
                                            HasShadow="False"
                                            BorderColor="Black"
                                            BackgroundColor="White"
                                            CornerRadius="8">
                                            <Image
                                                Source="{Binding .}"
                                                HeightRequest="60"
                                                WidthRequest="60"
                                                Aspect="AspectFit"
                                                HorizontalOptions="Center"/>
                                        </Frame>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                        </StackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <StackLayout
                Orientation="Horizontal"
                HorizontalOptions="Center"
                VerticalOptions="EndAndExpand"
                Spacing="20"
                Margin="0,0,0,30">

                <Button
                    Text="Keskeytä"
                    Clicked="KeskeytäClicked"
                    BackgroundColor="#FEBA4F"
                    TextColor="Black"
                    FontSize="20"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="70"
                    WidthRequest="150"
                    BorderColor="Transparent"
                    BorderWidth="0"/>

                <Button
                    Text="Jatka"
                    Clicked="JatkaClicked"
                    BackgroundColor="#FEBA4F"
                    TextColor="Black"
                    FontSize="20"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="70"
                    WidthRequest="150"
                    BorderColor="Transparent"
                    BorderWidth="0"/>
            </StackLayout>

        </StackLayout>
    </ContentPage.Content>
</ContentPage>
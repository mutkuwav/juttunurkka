<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Prototype.Kirjautuminen"
             Title="Juttunurkka"
             >
             <Grid>

        <!-- TAUSTAKUVA -->
        <Image
            Source="background2.png"
            Aspect="AspectFill"
            HorizontalOptions="Fill"
            VerticalOptions="Fill"/>

    <StackLayout VerticalOptions="CenterAndExpand" Spacing="10" Padding="0,0,0,50">
        <Label Text="Kirjaudu sisään opettajanhuoneeseen"
                VerticalOptions="CenterAndExpand" 
                HorizontalOptions="CenterAndExpand"
                HorizontalTextAlignment="Center"
                FontAttributes="Bold"
                FontFamily= "LineSeedBold"
                FontSize="30"
                TextColor="Black"
                Padding="0,0,0,40"
             />

        <Label Text="Käyttäjätunnus"
               FontFamily= "LineSeedBold"
                VerticalOptions= "EndAndExpand" 
                HorizontalOptions="StartAndExpand"
               FontSize="20"
               Margin="80,0,0,0"
             />
        <Frame
        HeightRequest="50"
        WidthRequest="255"
        CornerRadius="10"
        BackgroundColor="White"
        BorderColor="Transparent"
        Padding="15,0"
        HorizontalOptions="Center">

        <Entry
                x:Name="txtUsername"
                TextColor="Black"
                PlaceholderColor="Gray"
                BackgroundColor="Transparent"
                VerticalOptions="Center"
                HeightRequest="50"/>
        </Frame>
        
        <Label Text="Salasana"
                FontFamily= "LineSeedBold"
                VerticalOptions="EndAndExpand" 
                HorizontalOptions="StartAndExpand"
               FontSize="20"
               Margin="80,0,0,0"
             />
        <Frame
        HeightRequest="50"
        WidthRequest="255"
        CornerRadius="10"
        BackgroundColor="White"
        BorderColor="Transparent"
        Padding="15,0"
        HorizontalOptions="Center">

        <Entry
                x:Name="txtPassword"
                IsPassword="True"
                TextColor="Black"
                PlaceholderColor="Gray"
                BackgroundColor="Transparent"
                VerticalOptions="Center"
                HeightRequest="50"/>
                
        </Frame>
       
        
        <Button  
                Text="Kirjaudu"
                FontFamily= "LineSeedBold"
                VerticalOptions="CenterAndExpand" 
                HorizontalOptions="CenterAndExpand" 
                FontSize="19"
              Margin="20,40,10,5"
              TextColor="Black"
              CornerRadius="10"
              HeightRequest="50"
              WidthRequest="255"
              BackgroundColor="#bfd3c1"
              BorderWidth="0.1"
              BorderColor="Transparent"
              Clicked="KirjauduClicked"/>

    </StackLayout>

 </Grid>

</ContentPage> 
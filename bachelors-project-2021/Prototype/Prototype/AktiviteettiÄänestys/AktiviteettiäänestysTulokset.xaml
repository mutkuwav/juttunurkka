<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Prototype.AktiviteettiäänestysTulokset"
             BackgroundColor="Transparent"
             NavigationPage.HasNavigationBar="False">

    <AbsoluteLayout HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand" Padding="0">

        <Image Source="background3.png"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill"
               AbsoluteLayout.LayoutBounds="0, 0, 1, 1"
               AbsoluteLayout.LayoutFlags="All" />

        <Grid RowDefinitions="Auto,*,Auto"
              Padding="24,60,24,30"
              RowSpacing="20"
              AbsoluteLayout.LayoutBounds="0, 0, 1, 1"
              AbsoluteLayout.LayoutFlags="All">

            <!--Teksti-->
            <Label Grid.Row="0"
                   Text="TULOKSET"
                   FontFamily="LineSeedBold"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   FontSize="38"
                   FontAttributes="Bold"
                   TextColor="Black" />

            <!--Tulokset pylväinä-->
            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding Results}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="16"
                               Margin="0,8,0,8"
                               CornerRadius="16"
                               BackgroundColor="#bfd3c1"
                               BorderColor="Transparent"
                               HasShadow="False">

                            <Grid ColumnDefinitions="80,*,Auto"
                                  ColumnSpacing="16"
                                  VerticalOptions="Center">

                                <Image Grid.Column="0"
                                       Source="{Binding Image}"
                                       HeightRequest="64"
                                       WidthRequest="64"
                                       Aspect="AspectFit"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />

                                <Label Grid.Column="1"
                                       Text="{Binding Title}"
                                       VerticalOptions="Center"
                                       TextColor="Black"
                                       FontFamily="LineSeedBold"
                                       FontSize="20"
                                       LineBreakMode="WordWrap" />

                                <Frame Grid.Column="2"
                                       BackgroundColor="#a0baa3"
                                       CornerRadius="12"
                                       Padding="18,10"
                                       HasShadow="False"
                                       VerticalOptions="Center">

                                    <Label Text="{Binding Amount}"
                                           TextColor="Black"
                                           FontFamily="LineSeedBold"
                                           FontSize="22"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Frame>

                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        
            <!--Sulje huone -nappi-->
            <Button Grid.Row="2"
                    Text="SULJE HUONE"
                    Clicked="SuljeClicked"
                    BackgroundColor="#bfd3c1"
                    FontFamily="LineSeedBold"
                    TextColor="Black"
                    FontSize="22"
                    FontAttributes="Bold"
                    CornerRadius="16"
                    BorderColor="Transparent"
                    HeightRequest="86"
                    HorizontalOptions="Fill" />
        </Grid>
    </AbsoluteLayout>
</ContentPage>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Prototype.Opettajanhuone"
             Title="Juttunurkka">

    <Grid>

        <!-- TAUSTAKUVA -->
        <Image
            Source="background2.png"
            Aspect="AspectFill"
            HorizontalOptions="Fill"
            VerticalOptions="Fill" />

        <!-- SISÄLTÖ -->
        <StackLayout VerticalOptions="FillAndExpand"
                     Spacing="50"
                     Padding="0,100,0,0">

            <!-- Otsikko ja hammasratas -->
            <Grid RowDefinitions="Auto, Auto"
                  ColumnDefinitions="Auto, Auto">

                <Image Grid.Column="1"
                       Source="gear"
                       HeightRequest="45"
                       WidthRequest="45"
                       Scale="1.3"
                       Margin="-205,0,0,0" />

                <Label Grid.Column="2"
                       Text="Opettajanhuone"
                       FontFamily="LineSeedBold"
                       VerticalOptions="CenterAndExpand"
                       HorizontalOptions="CenterAndExpand"
                       HorizontalTextAlignment="Center"
                       FontAttributes="Bold"
                       FontSize="30"
                       TextColor="Black"
                       Padding="100,0,0,0" />
            </Grid>

            <!-- Painikkeet -->
            <Grid RowDefinitions="Auto, Auto, Auto"
                  ColumnDefinitions="Auto, Auto"
                  VerticalOptions="End"
                  Padding="10"
                  HorizontalOptions="CenterAndExpand">

                <Button Grid.Row="0"
                        Text="Luo uusi juttunurkka"
                        FontFamily="LineSeedBold"
                        Clicked="UusiJuttunurkkaClicked"
                        VerticalOptions="CenterAndExpand"
                        HorizontalOptions="CenterAndExpand"
                        FontSize="25"
                        Margin="0,0,0,0"
                        CornerRadius="10"
                        HeightRequest="100"
                        TextColor="Black"
                        FontAttributes="Bold"
                        BorderColor="Transparent"
                        WidthRequest="340"
                        BackgroundColor="#bfd3c1" />

                <Button Grid.Row="1"
                        Text="Arkisto"
                        FontFamily="LineSeedBold"
                        VerticalOptions="CenterAndExpand"
                        HorizontalOptions="CenterAndExpand"
                        BackgroundColor="#bfd3c1"
                        FontSize="25"
                        BorderColor="Transparent"
                        Margin="0,30,0,0"
                        CornerRadius="10"
                        HeightRequest="100"
                        FontAttributes="Bold"
                        TextColor="Black"
                        WidthRequest="340"
                        Clicked="ArkistoClicked" />

                <Button Grid.Row="2"
                        Text="Ohjeet"
                        FontFamily="LineSeedBold"
                        VerticalOptions="CenterAndExpand"
                        HorizontalOptions="CenterAndExpand"
                        BackgroundColor="#bfd3c1"
                        FontSize="25"
                        BorderColor="Transparent"
                        Margin="0,30,0,0"
                        CornerRadius="10"
                        HeightRequest="100"
                        FontAttributes="Bold"
                        TextColor="Black"
                        WidthRequest="340"
                        Clicked="OnBoardingClicked" />
            </Grid>

            <!-- OnBoarding kehikko -->
            <Frame x:Name="OnBoardingBox"
                   IsVisible="False"
                   BackgroundColor="White"
                   CornerRadius="15"
                   Padding="20"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   WidthRequest="300"
                   HasShadow="True">

                <VerticalStackLayout Spacing="15">
                    <Label Text="Ohjeet"
                           FontAttributes="Bold"
                           FontSize="20"
                           HorizontalOptions="Center" />

                    <Label Text="Tähän lyhyt ohjeteksti."
                           FontSize="16" />

                    <Button Text="Sulje"
                            Clicked="CloseOnBoardingClicked"
                            FontFamily="LineSeedRegular"
                            BackgroundColor="#f6c68a"
                            TextColor="Black"
                            CornerRadius="10" />
                </VerticalStackLayout>
            </Frame>

        </StackLayout>

    </Grid>
</ContentPage>

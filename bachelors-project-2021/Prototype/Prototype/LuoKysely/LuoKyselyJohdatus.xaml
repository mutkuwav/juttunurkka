<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Prototype.LuoKyselyJohdatus"
             Title="Juttunurkka">

    <!-- Grid layout mahdollistaa päällekkäin asetukset ja joustavan sijoittelun -->
    <Grid RowDefinitions="*, Auto, Auto, Auto, *"
          ColumnDefinitions="*">

        <!-- TAUSTAKUVA (alimmaisena) -->
        <Image Source="background2.png"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill"
               Grid.RowSpan="5"
               Grid.ColumnSpan="1" />

        <!-- Otsikko -->
        <Label Grid.Column="2" 
        Text="Luo juttunurkka" 
        FontFamily="LineSeedBold" 
        VerticalOptions="StartAndExpand" 
        HorizontalOptions="CenterAndExpand" 
        HorizontalTextAlignment="Center" 
        FontAttributes="Bold" 
        FontSize="30" 
        TextColor="Black" 
        Margin="0,50,0,0" />


        <!-- Pyöristetty Picker Frame:ssa -->
        <Frame HeightRequest="50"
               WidthRequest="340"
               CornerRadius="10"
               BackgroundColor="White"
               BorderColor="Transparent"
               Padding="10,0"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               Grid.Row="3">

            <Picker Title="Valitse kysymys"  
                    x:Name="KysymysPicker"
                    FontFamily="LineSeedRegular"
                    SelectedIndexChanged="OnPickerSelectedIndexChanged"
                    VerticalOptions="Center"
                    HorizontalOptions="FillAndExpand"
                    TextColor="Black"
                    TitleColor="Gray"
                    FontSize="20"
                    BackgroundColor="Transparent"
                    ItemsSource="{Binding Intros}"
                    ItemDisplayBinding="{Binding introMessage}">
                
                <Picker.Items>
                    <x:String>Mitä kuuluu tänään?</x:String>
                    <x:String>Miten viikonloppu meni?</x:String>
                    <x:String>Miten välitunti meni?</x:String>
                    <x:String>Mikä fiilis?</x:String>
                    <x:String>Mikä boogie?</x:String>
                    <x:String>Luo oma kysymys...</x:String>
                </Picker.Items>
            </Picker>

        </Frame>

        <!-- Buttonit Grid:ssä -->
        <Grid RowDefinitions="Auto"
              ColumnDefinitions="*,*"
              HorizontalOptions="Center"
              VerticalOptions="End"
              Margin="0,20,0,40"
              Grid.Row="4">

            <Button Grid.Column="0"
                    x:Name="EdellinenBtn"
                    Text="Edellinen"
                    Clicked="EdellinenButtonClicked"
                    BorderWidth="0"
                    BackgroundColor="#bfd3c1"
                    TextColor="Black"
                    FontFamily="LineSeedBold"
                    FontAttributes="Bold"
                    FontSize="19"
                    CornerRadius="10"
                    HeightRequest="50"
                    WidthRequest="150"
                    Margin="20,0,10,0" />

            <Button Grid.Column="1"
                    x:Name="JatkaBtn"
                    Text="Jatka"
                    IsEnabled="False"
                    Clicked="JatkaButtonClicked"
                    BackgroundColor="#bfd3c1"
                    TextColor="Black"
                    FontFamily="LineSeedBold"
                    FontAttributes="Bold"
                    FontSize="19"
                    BorderWidth="0"
                    CornerRadius="10"
                    HeightRequest="50"
                    WidthRequest="150"
                    Margin="10,0,20,0" />

        </Grid>

    </Grid>

</ContentPage>
